{
  "name": "atolye-platform-client",
  "version": "3.5.0",
  "type": "module",
  "description": "Atolye Platform Smart Client with Auto-Discovery",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:linux-dir": "electron-builder --linux dir"
  },
  "author": "Emirhan Gök",
  "license": "MIT",
  "dependencies": {
    "bonjour-service": "^1.2.1"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.atolye.platform",
    "productName": "Atolye Platform",
    "linux": {
      "target": [
        "deb",
        "dir"
      ],
      "category": "Education"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "directories": {
      "output": "dist"
    }
  }
}
