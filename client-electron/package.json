{
  "name": "atolye-platform-client",
  "version": "4.1.0",
  "type": "module",
  "description": "Atolye Platform Smart Client with Auto-Discovery",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:linux-dir": "electron-builder --linux dir"
  },
  "author": "Emirhan Gök",
  "license": "MIT",
  "dependencies": {
    "bonjour-service": "^1.2.1",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.atolye.platform",
    "productName": "Atolye Platform",
    "linux": {
      "target": [
        "deb",
        "dir"
      ],
      "category": "Education"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "identity": null
    },
    "directories": {
      "output": "dist"
    },
    "publish": [
      {
        "provider": "generic",
        "url": "http://127.0.0.1:3002/updates"
      }
    ]
  }
}
